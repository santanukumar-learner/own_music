# Copy to `.env` and fill in. Nothing here is committed (.env is git-ignored).

SONATA_HOST=0.0.0.0
SONATA_PORT=8973
SONATA_MAX_UPLOAD_MB=60

# AcoustID application API key (free): https://acoustid.org/new-application
# Without it, fingerprint lookup is skipped and the pipeline falls back to
# MusicBrainz text search.
ACOUSTID_API_KEY=

# Last.fm API key (optional fallback): https://www.last.fm/api/account/create
LASTFM_API_KEY=

# Discogs personal access token (optional fallback):
# https://www.discogs.com/settings/developers
DISCOGS_TOKEN=

# MusicBrainz needs a descriptive User-Agent (no key). Identify your app.
MB_APP_NAME=SonataMusicPlayer
MB_APP_VERSION=0.1.0
MB_CONTACT=founder@helprevx.com

# ONNX genre model (fetched separately — see models/README.md).
SONATA_MODEL_PATH=models/genre_model.onnx
SONATA_LABELS_PATH=models/genre_labels.txt
